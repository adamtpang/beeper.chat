{
  "name": "beeper-chat-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop app for beeper.chat — opens your importance x urgency inbox in its own window.",
  "author": "Adam Pangelinan",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.2"
  },
  "build": {
    "appId": "chat.beeper.triage",
    "productName": "beeper.chat",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/node_modules/**"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
