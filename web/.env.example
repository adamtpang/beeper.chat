# Copy to .env and fill in to go live (otherwise the app runs in DEMO mode).

# Required for live ranking
ANTHROPIC_API_KEY=
# Beeper Desktop local API access token (from the Desktop API auth flow)
BEEPER_ACCESS_TOKEN=

# Optional
DEMO=1                                   # set to 0 to use real Beeper + Claude
ANTHROPIC_MODEL=claude-sonnet-4-6        # triage model
BEEPER_API_BASE=http://127.0.0.1:23373   # Beeper Desktop local API
PORT=4317
