# Copy to .env to go live (otherwise the app runs in DEMO mode).

# Beeper Desktop access token (REQUIRED for live). In Beeper Desktop:
# Settings -> Integrations -> Approved connections -> + (create token).
# Treat it like a password: it can read and send your messages.
BEEPER_ACCESS_TOKEN=

DEMO=1                                    # set to 0 to use your real inbox

# Ranking uses your Claude SUBSCRIPTION by default (no API credits), through the
# Claude Code CLI. Requires Claude Code installed and logged in.
LLM=cli
CLAUDE_MODEL=sonnet

# To use a pay-as-you-go API key instead, uncomment these:
# LLM=api
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

BEEPER_API_BASE=http://127.0.0.1:23373
PORT=4317
